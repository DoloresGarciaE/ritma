# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# playwright (F0.7)
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...except the versioned template (Plan §5): real secrets stay in .env.local / Vercel.
!.env.example
# ...and .env.test: solo credenciales de un Postgres local y descartable (F0.6), sin secretos.
!.env.test

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma: cliente generado (se regenera con `prisma generate`, en postinstall y build)
/src/generated/
